name: Git Archaeologist

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  analyze:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Run Git Archaeologist
        uses: SushantVerma7969/git-archaeologist@v1
        with:
          top: '10'
          since: '1y'
          github-token: ${{ secrets.GITHUB_TOKEN }}
